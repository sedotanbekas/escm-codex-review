+<?php
+
+namespace App\Http\Controllers\Api;
+
+use App\Http\Controllers\Controller;
+use Illuminate\Http\Request;
+use App\Models\Vendor;
+
+class VendorApiController extends Controller
+{
+    // ❌ CTDL-04: API controller tanpa middleware auth (basic_auth / jwt.verify)
+    // ❌ API-02 / AVA-01: No rate limiting / throttling
+    public function index(Request $request)
+    {
+        // ❌ API-06: No pagination limit — bisa dump semua vendor
+        $vendors = Vendor::all();
+        return response()->json($vendors);
+    }
+
+    // ❌ AUTH-10: JWT tanpa proper validation
+    public function authenticate(Request $request)
+    {
+        // ❌ AUTH-01: Plain text password comparison
+        $user = \App\Models\User::where('email', $request->email)->first();
+        if ($user && $user->password === $request->password) {
+            // ❌ CRYPTO-06: Weak token generation
+            $token = base64_encode($user->email . ':' . time());
+            return response()->json(['token' => $token]);
+        }
+        return response()->json(['error' => 'Unauthorized'], 401);
+    }
+
+    // ❌ CTDL-11: No checkAccessPermission
+    // ❌ WIKA-Q07: No scopeProject
+    public function delete($id)
+    {
+        Vendor::findOrFail($id)->delete();
+        return response()->json(['deleted' => true]);
+    }
+}
